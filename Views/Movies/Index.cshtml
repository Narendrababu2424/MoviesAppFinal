@model IEnumerable<MoviesAppFinal.Models.Movie>

@{
    ViewData["Title"] = "Movies List";
}

<!-- Student Name: Muni Narendra -->
<!-- Student ID: 90808789 -->

<h2 class="text-center text-white bg-primary p-3 my-3">
    Top Box Office
</h2>

<div class="text-end mb-3">
    <a asp-action="Create" class="btn btn-success">
        Add New Movie
    </a>
</div>

<table class="table table-striped table-bordered text-center">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Release Year</th>
            <th>Genre</th>
            <th>Poster</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var movie in Model)
        {
            <tr>
                <td>@movie.Title</td>
                <td>@movie.ReleaseYear</td>
                <td>@movie.Genre</td>

                <td>
                    <a asp-action="Details" asp-route-id="@movie.Id">
                        <img src="@Url.Content("~/image/" + movie.ImageUrl)"
                             style="width:80px;height:100px"
                             class="img-thumbnail" />
                    </a>
                </td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@movie.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@movie.Id"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>